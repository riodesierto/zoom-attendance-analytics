# Credenciales de la app Server-to-Server OAuth de Zoom.
# Copia este archivo como `.env` y completa con tus valores reales.
# NUNCA subas el archivo .env al repositorio.
#
# Scopes requeridos en la app de Zoom Marketplace:
#   dashboard:read:list_meetings:admin
#   dashboard:read:list_meeting_participants:admin

ZOOM_ACCOUNT_ID=tu_account_id
ZOOM_CLIENT_ID=tu_client_id
ZOOM_CLIENT_SECRET=tu_client_secret
